# AFAMAR Backend — Recommended development .env
#
# Copy this file to `.env` and adjust values for your local setup:
#   cp .env.example .env
#
# `.env` is gitignored — never commit real secrets.

# Application
ENVIRONMENT=development
APP_NAME=AFAMAR API
APP_VERSION=1.1.0
APP_DESCRIPTION=API de gestión de documentos
DEBUG=false

# Database (only used when ENVIRONMENT != development)
DB_USER=afamar
DB_PASSWORD=
DB_HOST=mysql-central
DB_PORT=3306
DB_NAME=afamar
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# SMTP (optional — for sending emails from the app)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# WhatsApp (optional — for WhatsApp notifications)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# JWT — REPLACE BEFORE DEPLOYING. Generate with: openssl rand -hex 32
SECRET_KEY=afamar-dev-secret-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=168

# CORS — comma-separated list, or "*" to allow all (dev only)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3090

# Frontend
FRONTEND_URL=http://localhost:3090

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Rate limiting (slowapi format: "N/period")
# - RATE_LIMIT_LOGIN: high enough for E2E test suites + normal user retries
# - RATE_LIMIT_REGISTER: keep low — prevents account-spam attacks
# - Set RATE_LIMIT_ENABLED=false in test environments to disable entirely
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN=60/minute
RATE_LIMIT_REGISTER=3/minute